class Solution:
    def rearrangeArray(self, nums: List[int]) -> List[int]:

        positives = []
        negatives = []
        for x in nums:
            if x > 0:
                positives.append(x)
            else:
                negatives.append(x)
        ans = []
        for i in range(len(positives)):
            ans.append(positives[i])
            ans.append(negatives[i])
        return ans

class Solution:
    def findMedianSortedArrays(self, nums1: List[int], nums2: List[int]) -> float:
        merge=nums1+nums2
        merge.sort()
        n=len(merge)
        if n%2==1:
            median=merge[n//2]
        else:
            median=(merge[n//2-1]+merge[n//2])/2
        return median
